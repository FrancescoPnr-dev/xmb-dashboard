<?xml version="1.0" encoding="UTF-8"?>
<!--
    KConfigXT schema. Every <entry> here becomes available in QML as
    Plasmoid.configuration.<name> (read/write, auto-persisted).
-->
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
                          http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>

    <group name="General">
        <!-- Darkness of the fullscreen overlay (0 = transparent, 1 = opaque black). -->
        <entry name="backgroundOpacity" type="Double">
            <default>0.85</default>
        </entry>

        <!-- Icon size (px) of the selected category on the horizontal bar. -->
        <entry name="categoryIconSize" type="Int">
            <default>112</default>
        </entry>

        <!-- Icon size (px) of the selected app in the vertical column. -->
        <entry name="appIconSize" type="Int">
            <default>56</default>
        </entry>

        <!-- Horizontal position of the fixed cross intersection, as a
             fraction of the screen width (0.30 = classic PS3 center-left). -->
        <entry name="intersectionXFraction" type="Double">
            <default>0.30</default>
        </entry>

        <!-- Icon shown on the panel for this widget. -->
        <entry name="panelIcon" type="String">
            <default>applications-all</default>
        </entry>

        <!-- Display names of categories the user chose to hide from the bar. -->
        <entry name="hiddenCategories" type="StringList">
            <default></default>
        </entry>

        <!-- Ordered list of favourite application IDs, backing the "Favourites" category.
             Read/written by the kicker favourites model (KAStatsFavoritesModel), shared
             with kactivitymanagerd — same mechanism Kickoff uses. -->
        <entry name="favorites" type="StringList">
            <default></default>
        </entry>

        <!-- ===== Category-bar mouse "hot zone" feel ===== -->

        <!-- Width of the LEFT edge hot zone, as a fraction of screen width. -->
        <entry name="hotZoneFractionLeft" type="Double">
            <default>0.15</default>
        </entry>

        <!-- Width of the RIGHT edge hot zone, as a fraction of screen width. -->
        <entry name="hotZoneFractionRight" type="Double">
            <default>0.45</default>
        </entry>

        <!-- Scroll speed (px/sec) just inside the hot-zone threshold (fine control). -->
        <entry name="minScrollSpeed" type="Int">
            <default>1500</default>
        </entry>

        <!-- Scroll speed (px/sec) at the extreme screen edge (fastest). -->
        <entry name="maxScrollSpeed" type="Int">
            <default>2600</default>
        </entry>

        <!-- Duration (ms) of the snap-to-nearest animation when leaving the hot zone. -->
        <entry name="snapDuration" type="Int">
            <default>220</default>
        </entry>

        <!-- Magnetic "glue" strength near category centres (0 = none .. ~1 = strong). -->
        <entry name="magneticStrength" type="Double">
            <default>0.7</default>
        </entry>

        <!-- Height (px) of the vertical band, centred on the category row, within
             which the left/right hot zones are active. Outside it (where the app
             column lives) approaching the edges does not scroll categories. -->
        <entry name="hotZoneBandHeight" type="Int">
            <default>360</default>
        </entry>

        <!-- Temporarily disable Plasma's screen-EDGE actions (switch-desktop-on-edge)
             while the dashboard is open, restoring them on close. Reversible; touches
             only kwinrc [Windows] ElectricBorders. -->
        <entry name="manageScreenEdges" type="Bool">
            <default>false</default>
        </entry>

        <!-- ===== XMB wave background (Qt6 ShaderEffect port of the linkev
             ps3xmbwave demo). Defaults mirror the demo's spline-settings.js /
             particles-settings.js so the default look matches the demo. ===== -->

        <!-- Wave -->
        <entry name="waveFlowSpeed" type="Double"><default>0.25</default></entry>
        <entry name="waveBandAmplitude" type="Double"><default>0.2</default></entry>
        <entry name="waveHeightScale" type="Double"><default>0.5</default></entry>
        <entry name="waveSoftClip" type="Double"><default>0.22</default></entry>
        <entry name="waveTension" type="Double"><default>0.12</default></entry>
        <entry name="waveFresnelPower" type="Double"><default>4.0</default></entry>
        <entry name="waveFresnelScale" type="Double"><default>0.5</default></entry>
        <entry name="waveOpacity" type="Double"><default>0.7</default></entry>
        <entry name="waveBrightness" type="Double"><default>0.98</default></entry>
        <entry name="waveRowCount" type="Int"><default>200</default></entry>

        <!-- Gradient / colour. waveColorMonth: 0 = Automatic (current month's PS3
             preset), 1..12 = forced month preset, 13 = Custom (RGB sliders below). -->
        <entry name="waveColorMonth" type="Int"><default>0</default></entry>
        <entry name="waveColorR" type="Int"><default>37</default></entry>
        <entry name="waveColorG" type="Int"><default>89</default></entry>
        <entry name="waveColorB" type="Int"><default>179</default></entry>
        <entry name="waveGradientTopMul" type="Double"><default>0.09</default></entry>
        <entry name="waveGradientBotMul" type="Double"><default>0.62</default></entry>

        <!-- Particles -->
        <entry name="waveParticlesEnabled" type="Bool"><default>true</default></entry>
        <entry name="waveParticleCount" type="Int"><default>2000</default></entry>
        <entry name="waveParticleOpacity" type="Double"><default>0.9</default></entry>
        <entry name="waveParticleFlowSpeed" type="Double"><default>0.8</default></entry>
    </group>
</kcfg>
